{
	"name": "chance-ui",
	"description": "I am Chance, and this repository is for building UIs.",
	"author": "Chance Strickland <hi@chancedigital.io>",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/chaance/chance-ui.git"
	},
	"scripts": {
		"bootstrap": "make bootstrap",
		"test": "cross-env CI=true ts-node ./scripts/test packages",
		"test:pkg": "cross-env CI=true ts-node ./scripts/test --pkg",
		"test:coverage": "yarn test --coverage",
		"build": "make build",
		"build:pkg": "node -r ts-node/register scripts/build-package",
		"ver": "lerna version --no-push --exact",
		"changes": "dotenv lerna-changelog",
		"clean": "make clean",
		"clean:build": "make clean-build",
		"lint": "eslint ."
	},
	"keywords": [
		"ui",
		"a11y",
		"frontend",
		"react",
		"components"
	],
	"dependencies": {
		"@babel/core": "^7.12.3",
		"@babel/plugin-proposal-class-properties": "^7.12.1",
		"@babel/plugin-proposal-nullish-coalescing-operator": "^7.12.1",
		"@babel/plugin-proposal-optional-chaining": "^7.12.1",
		"@babel/preset-env": "^7.12.1",
		"@rollup/plugin-babel": "^5.2.1",
		"@rollup/plugin-commonjs": "^16.0.0",
		"@rollup/plugin-node-resolve": "^10.0.0",
		"@rollup/plugin-replace": "^2.3.4",
		"@testing-library/dom": "^7.26.3",
		"@testing-library/jest-dom": "^5.11.5",
		"@testing-library/react": "^11.1.0",
		"@testing-library/user-event": "^12.1.10",
		"@types/eslint": "^7.2.4",
		"@types/fs-extra": "^9.0.2",
		"@types/jest": "^26.0.15",
		"@types/jest-axe": "^3.5.1",
		"@types/lodash": "^4.14.163",
		"@types/mri": "^1.1.0",
		"@types/node": "^14.14.6",
		"@types/react": "^16.9.55",
		"@types/react-dom": "^16.9.9",
		"@types/react-test-renderer": "^16.9.3",
		"@types/rimraf": "^3.0.0",
		"@types/rollup-plugin-sourcemaps": "0.4.2",
		"@types/sinon": "^9.0.8",
		"@typescript-eslint/eslint-plugin": "^4.6.0",
		"@typescript-eslint/parser": "^4.6.0",
		"babel-eslint": "^10.1.0",
		"babel-jest": "^26.6.1",
		"babel-plugin-annotate-pure-calls": "0.4.0",
		"babel-plugin-dev-expression": "0.2.2",
		"chalk": "^4.1.0",
		"confusing-browser-globals": "^1.0.10",
		"cross-env": "^7.0.2",
		"dotenv-cli": "^4.0.0",
		"eslint": "^7.12.1",
		"eslint-plugin-import": "^2.22.0",
		"eslint-plugin-jest": "^24.1.0",
		"eslint-plugin-jsx-a11y": "^6.4.1",
		"eslint-plugin-react": "^7.20.6",
		"eslint-plugin-react-hooks": "^4.2.0",
		"eslint-plugin-testing-library": "^3.10.0",
		"fs-extra": "^9.0.1",
		"husky": "^4.3.0",
		"jest": "^26.6.1",
		"jest-watch-typeahead": "0.6.1",
		"jest-axe": "^4.0.0",
		"lerna": "^3.22.1",
		"lerna-changelog": "^1.0.1",
		"lerna-script": "^1.3.2",
		"lodash": "^4.17.20",
		"mri": "^1.1.6",
		"prettier": "^2.1.2",
		"pretty-ms": "^7.0.1",
		"pretty-quick": "^3.1.0",
		"progress-estimator": "0.3.0",
		"prop-types": "^15.7.2",
		"react": "^16.14.0",
		"react-dom": "^16.14.0",
		"react-test-renderer": "^16.14.0",
		"rimraf": "^3.0.2",
		"rollup": "^2.32.1",
		"rollup-plugin-sourcemaps": "0.6.3",
		"rollup-plugin-terser": "^7.0.2",
		"rollup-plugin-typescript2": "0.28.0",
		"sinon": "^9.2.1",
		"ts-jest": "^26.4.3",
		"ts-node": "^9.0.0",
		"typescript": "^4.0.5"
	},
	"resolutions": {
		"@types/react": "^16.9.55",
		"@types/react-dom": "^16.9.9"
	},
	"workspaces": [
		"packages/*"
	],
	"eslintIgnore": [
		"node_modules",
		"dist"
	],
	"husky": {
		"hooks": {
			"pre-commit": "pretty-quick --staged"
		}
	},
	"prettier": {
		"semi": true,
		"trailingComma": "es5",
		"useTabs": true
	}
}
